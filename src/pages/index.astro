---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import Heading from "../components/ui/Heading.astro";
import Hero from "../components/ui/Hero.astro";
import Button from "../components/ui/Button.astro";
import { ArrowRight } from "@lucide/astro";
import ClientCarousel from "../components/ClientCarousel.astro";
import FeatureShowcase from "../components/FeatureShowcase.astro";
import ChannelFeature from "../components/ui/ChannelFeature.astro";
import { ROUTES } from "../lib/routes";
import SlideBoxSteps from "../components/SlideBoxSteps.astro";
import ApiSection from "../components/ApiSection.astro";
import Badge from "../components/ui/Badge.astro";
import TestimonialDiv from "../components/TestimonialDiv.astro";
import { Image } from "astro:assets";

// Importações de imagens para otimização do Astro
import heroImage from "../assets/images/home-hero-image.webp";
import labelHero from "../assets/images/label-hero-home.webp";
import whatsappImg from "../assets/images/whatsapp_marketing.webp";
import rcsImg from "../assets/images/rcs.webp";
import smsImg from "../assets/images/disparo_de_sms.webp";
import vozImg from "../assets/images/disparo_de_voz.webp";
import emailImg from "../assets/images/disparo_de_email.webp";

const CHANNEL_FEATURES = [
  {
    badge: "O canal favorito do cliente",
    title: "WhatsApp Marketing",
    features: [
      "Parceira oficial do WhatsApp",
      "Jornadas automatizadas",
      "Zero taxa de setup",
      "Usuários ilimitados",
    ],
    buttonText: "Saiba mais",
    buttonHref: ROUTES.CANAIS.WHATSAPP,
    imageSrc: whatsappImg,
    imageAlt: "WhatsApp Marketing Dashboard",
  },
  {
    badge: "Conversão garantida",
    title: "RCS",
    features: [
      "Mensagens multimídia",
      "Botões interativos",
      "Sua marca verificada pela Meta",
      "Zero taxa de setup",
    ],
    buttonText: "Saiba mais",
    buttonHref: ROUTES.CANAIS.RCS,
    imageSrc: rcsImg,
    imageAlt: "RCS",
    reverse: true,
  },
  {
    badge: "Melhor custo-benefício",
    title: "Disparo de SMS",
    features: [
      "Até 98% de alcance",
      "Segmentação de contatos",
      "Mensagens personalizadas",
      "Dados em tempo real",
    ],
    buttonText: "Saiba mais",
    buttonHref: ROUTES.CANAIS.SMS,
    imageSrc: smsImg,
    imageAlt: "Disparo de SMS",
  },
  {
    badge: "Comunicação humanizada ",
    title: "Disparo de Voz",
    features: [
      "Pague apenas por chamadas atendidas",
      "Integração direta com SMS",
      "Gere áudios com IA",
      "Dados em tempo real",
    ],
    buttonText: "Saiba mais",
    buttonHref: ROUTES.CANAIS.VOZ,
    imageSrc: vozImg,
    imageAlt: "Disparo de Voz",
    reverse: true,
  },
  {
    badge: "Tradicional que funciona",
    title: "Disparo de E-mail",
    features: [
      "Programe jornadas completas",
      "Mensagens personalizadas",
      "Zero taxa de setup",
      "Suporte em tempo real",
    ],
    buttonText: "Saiba mais",
    buttonHref: ROUTES.CONTATO,
    imageSrc: emailImg,
    imageAlt: "Disparo de E-mail",
  },
];
---

<BaseLayout>
  <Hero id="home" class="bg-surface-default relative overflow-hidden">
    <!-- Glow roxo -->
    <div
      class="pointer-events-none absolute -bottom-[220px] left-2/6 w-[428px] h-[428px] rounded-full bg-brand-secondary blur-[100px]"
    >
    </div>

    <!-- Glow rosa -->
    <div
      class="pointer-events-none absolute -bottom-[364px] right-0 w-[800px] h-[800px] rounded-full bg-brand-primary blur-[100px]"
    >
    </div>

    <div
      class="w-full lg:w-[48%] flex flex-col items-start gap-6 md:gap-8 lg:gap-4 xl:gap-8 relative z-10"
    >
      <Badge text="Junte-se a 20mil empresas" image={labelHero} />

      <div class="flex flex-col gap-4 md:gap-6 lg:gap-4 xl:gap-6 items-start">
        <Heading as="h1">
          Impulsione suas vendas com jornadas completas<br /> e personalizadas.
        </Heading>
        <p class="text-body-md text-text-secondary max-w-[500px]">
          Dispare WhatsApp, RCS, SMS, E-mail e Voz<br /> em um só lugar.
        </p>
      </div>
      <Button variant="primary" icon={ArrowRight} href={ROUTES.CONTATO}
        >Comece agora</Button
      >
    </div>
    <div class="w-full lg:w-1/2 relative z-10">
      <Image
        src={heroImage}
        alt="Plataforma Disparo Pro"
        class="w-full h-auto"
        loading="eager"
        fetchpriority="high"
        width={800}
        quality="mid"
        format="webp"
      />
    </div>
  </Hero>

  <ClientCarousel />

  <Section>
    <FeatureShowcase />
  </Section>

  <div class="bg-surface-muted w-full">
    <Section>
      <div class="flex flex-col gap-6 lg:gap-12">
        {CHANNEL_FEATURES.map((feature) => <ChannelFeature {...feature} />)}
      </div>
    </Section>
  </div>

  <Section
    containerClass="flex flex-col items-center justify-center gap-8 lg:gap-12"
  >
    <div
      class="mx-auto w-full xl:max-w-3/4 flex flex-col gap-4 lg:gap-6 items-center justify-center"
    >
      <Heading as="h2" class="text-center"
        >Crie e dispare jorndas de comunicação com poucos cliques</Heading
      >
      <p class="text-body-md text-text-secondary text-center">
        Na Disparo Pro, criar suas jornadas de comunicação é fácil e intuitivo.
        Confira o passo a passo:
      </p>
      <Button variant="primary" icon={ArrowRight} href={ROUTES.LOGIN}
        >Crie sua conta agora!</Button
      >
    </div>

    <SlideBoxSteps />
  </Section>

  <Section>
    <ApiSection
      title="Integre nossa API ao seu sistema!"
      description="Com a Disparo Pro, você tem acesso a APIs de WhatsApp, RCS, SMS, E-mail e Voz – tudo com suporte nacional e integração facilitada aos principais CRMs do mercado."
    />
  </Section>

  <Section>
    <TestimonialDiv />
  </Section>
</BaseLayout>
