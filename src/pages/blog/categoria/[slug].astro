---
import BlogLayout from "../../../layouts/BlogLayout.astro";
import BlogGrid from "../../../components/BlogGrid.astro";
import { getBlogPosts } from "../../../types/blog";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  
  // Find unique category slugs
  const categorySlugs = [...new Set(posts.map((post) => post.categorySlug))];
  
  return categorySlugs.map((slug) => {
    // Acha o nome da categoria para o slug
    const categoryName = posts.find(p => p.categorySlug === slug)?.category || slug;
    return {
      params: { slug },
      props: { category: categoryName, slug },
    };
  });
}

const { category, slug } = Astro.props;
const allPosts = await getBlogPosts();
const posts = allPosts.filter((post) => post.categorySlug === slug);

const seo = {
  title: `Categoria: ${category} - Blog Disparo Pro`,
  description: `Artigos da categoria ${category}.`,
};
---

<BlogLayout
  seo={seo}
  title={`Categoria: ${category}`}
  description={`Todos os artigos em ${category}`}
>
  <BlogGrid posts={posts} currentCategory={slug} />
</BlogLayout>
