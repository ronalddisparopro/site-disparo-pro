---
import BlogLayout from "../../layouts/BlogLayout.astro";
import BlogGrid from "../../components/BlogGrid.astro";
import { getBlogPosts } from "../../types/blog";
import { supabase } from "../../lib/supabase";

const posts = await getBlogPosts();

const seo = {
  title: "Blog - Disparo Pro",
  description: "Artigos sobre comunicação, APIs, WhatsApp e muito mais.",
};
---

<BlogLayout
  seo={seo}
  title="Blog da Disparo Pro"
  description="Dicas, tutoriais e novidades sobre as melhores ferramentas de comunicação."
>
  <BlogGrid posts={posts} />
</BlogLayout>
