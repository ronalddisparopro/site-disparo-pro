---
import Heading from "./ui/Heading.astro";
import { Image } from "astro:assets";

import jornadasImg from "../assets/images/jornadas-integradas.svg";
import apiImg from "../assets/images/api-gratuita.svg";
import dadosImg from "../assets/images/visualizacao-de-dados.svg";
import disparoSimplesImg from "../assets/images/disparo-simples.svg";

const features = [
  {
    id: "jornadas",
    title: "Jornadas integradas",
    description:
      "WhatsApp, RCS, SMS, Voz e E-mail <strong>em um só lugar</strong>.",
    image: jornadasImg,
  },
  {
    id: "disparo-simples",
    title: "Disparo Simples",
    description:
      "Use templates prontos para <strong>disparar com facilidade</strong>.",
    image: disparoSimplesImg,
  },
  {
    id: "api",
    title: "API Facilitada",
    description:
      "Integração com <strong>Playtech, Smartico, Optimove</strong> e mais.",
    image: apiImg,
  },
  {
    id: "dados",
    title: "Visualização de Dados",
    description: "Confira seu <strong>desempenho em tempo real</strong>.",
    image: dadosImg,
  },
];
---

<div class="flex flex-col gap-12 lg:gap-20 max-w-7xl mx-auto px-4">
  <div class="text-center flex flex-col gap-6 max-w-3xl mx-auto">
    <Heading as="h2" variant="primary">Assine, carregue e dispare!</Heading>
    <p class="text-text-secondary text-body-md">
      Com a Disparo Pro, criar e enviar jornadas de comunicação é fácil e
      prático.
    </p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-center">
    <!-- Menus on the left -->
    <div class="lg:col-span-4 flex flex-col gap-4 order-2 lg:order-1">
      {
        features.map((feature, index) => (
          <button
            data-feature-id={feature.id}
            data-index={index}
            class:list={[
              "feature-card text-left p-6 rounded-2xl transition-all duration-300 cursor-pointer group flex flex-col border-none",
              index === 0 ? "active bg-brand-soft" : "bg-transparent",
            ]}
          >
            <span
              class:list={[
                "text-label font-extrabold transition-colors",
                index === 0
                  ? "text-brand-primary"
                  : "text-text-primary group-hover:text-brand-primary",
              ]}
            >
              {feature.title}
            </span>
            <div
              class:list={[
                "description-wrapper grid transition-all duration-500 ease-in-out",
                index === 0
                  ? "grid-rows-[1fr] opacity-100"
                  : "grid-rows-[0fr] opacity-0",
              ]}
            >
              <div class="overflow-hidden">
                <p
                  class="text-body-sm text-text-secondary leading-relaxed pt-3"
                  set:html={feature.description}
                />
              </div>
            </div>
          </button>
        ))
      }
    </div>

    <!-- Image on the right -->
    <div
      class="lg:col-span-8 order-1 lg:order-2 relative w-full aspect-1014/634 rounded-2xl overflow-hidden border border-border-default bg-white group/image"
    >
      {
        features.map((feature, index) => (
          <div
            id={`image-${feature.id}`}
            class:list={[
              "feature-image absolute inset-0 transition-all duration-700 ease-in-out transform",
              index === 0
                ? "opacity-100 scale-100 z-10"
                : "opacity-0 scale-102 z-0",
            ]}
          >
            <Image
              src={feature.image as any}
              alt={feature.title}
              class="w-full h-full object-cover"
              width={1014}
              height={634}
              format="webp"
              quality="mid"
            />
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  function initFeatureShowcase() {
    const cards = document.querySelectorAll(".feature-card");
    const images = document.querySelectorAll(".feature-image");

    cards.forEach((card) => {
      card.addEventListener("click", () => {
        const featureId = card.getAttribute("data-feature-id");

        // Update Cards
        cards.forEach((c) => {
          c.classList.remove("active", "bg-brand-soft");
          c.classList.add("bg-transparent", "border-transparent");

          const title = c.querySelector("span");
          if (title) {
            title.classList.remove("text-brand-primary");
            title.classList.add("text-text-primary");
          }

          const desc = c.querySelector(".description-wrapper");
          if (desc) {
            desc.classList.remove("grid-rows-[1fr]", "opacity-100");
            desc.classList.add("grid-rows-[0fr]", "opacity-0");
          }
        });

        // Activate clicked card
        card.classList.add(
          "active",
          "bg-brand-soft",
          "border-transparent",
        );
        card.classList.remove("bg-transparent", "border-transparent");

        const activeTitle = card.querySelector("span");
        if (activeTitle) {
          activeTitle.classList.add("text-brand-primary");
          activeTitle.classList.remove("text-text-primary");
        }

        const activeDesc = card.querySelector(".description-wrapper");
        if (activeDesc) {
          activeDesc.classList.add("grid-rows-[1fr]", "opacity-100");
          activeDesc.classList.remove("grid-rows-[0fr]", "opacity-0");
        }

        // Update Images
        images.forEach((img) => {
          if (img.id === `image-${featureId}`) {
            img.classList.add("opacity-100", "z-10");
            img.classList.remove("opacity-0", "z-0");
          } else {
            img.classList.remove("opacity-100", "z-10");
            img.classList.add("opacity-0", "z-0");
          }
        });
      });
    });
  }

  document.addEventListener("astro:page-load", initFeatureShowcase);
  initFeatureShowcase();
</script>

<style>
  .feature-card {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .description-wrapper {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>
