---
export interface Props {
  author: string;
  publishedAt: string;
}

const { author, publishedAt } = Astro.props;
import { formatDate } from "../lib/utils";
---

<div
  class="flex items-center space-x-4 border-t border-b border-border-default/40 py-6 my-6"
>
  <div
    class="shrink-0 bg-surface-muted h-12 w-12 rounded-full flex items-center justify-center text-text-secondary font-bold text-lg"
  >
    {author.charAt(0).toUpperCase()}
  </div>
  <div>
    <h3 class="text-base font-bold text-text-primary">{author}</h3>
    <p class="text-sm text-text-tertiary">
      Publicado em <time datetime={publishedAt}>{formatDate(publishedAt)}</time>
    </p>
  </div>
</div>
