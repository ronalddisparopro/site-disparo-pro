---
export interface Props {
  author: string;
  publishedAt: string;
}

const { author, publishedAt } = Astro.props;
import { formatDate } from "../lib/utils";
---

<div
  class="flex items-center space-x-4 border-t border-b border-gray-200 py-6 my-8"
>
  <div
    class="flex-shrink-0 bg-gray-200 h-12 w-12 rounded-full flex items-center justify-center text-gray-600 font-bold text-lg"
  >
    {author.charAt(0).toUpperCase()}
  </div>
  <div>
    <h3 class="text-base font-bold text-gray-900">{author}</h3>
    <p class="text-sm text-gray-500">
      Publicado em <time datetime={publishedAt}>{formatDate(publishedAt)}</time>
    </p>
  </div>
</div>
