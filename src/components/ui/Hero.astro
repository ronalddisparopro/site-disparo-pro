---
import { cx } from "../../lib/utils";
import Container from "./Container.astro";

export interface Props {
  class?: string;
  id?: string;
  containerClass?: string;
}

const { class: className, id, containerClass, ...rest } = Astro.props;
---

<section
  id={id}
  class={cx("overflow-hidden pt-12 lg:pt-24 xl:pt-36", className)}
>
  <Container
    class={cx(
      "flex flex-col lg:flex-row items-start lg:items-center xl:items-start justify-between gap-12 lg:gap-8 xl:gap-0 px-4 md:px-6 xl:px-0",
      containerClass,
    )}
  >
    <slot />
  </Container>
</section>
