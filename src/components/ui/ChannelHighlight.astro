---
import { cx } from "../../lib/utils";
import Button from "./Button.astro";
import Heading from "./Heading.astro";
import { Image } from "astro:assets";
import Icon from "../Icon.astro";

export interface Item {
  icon: string | any;
  title: string;
  description: string;
}

export interface Props {
  items?: Item[];
  imageSrc: string | any;
  imageAlt: string;
  buttonText: string;
  buttonHref?: string;
  class?: string;
}

const {
  items = [],
  imageSrc,
  imageAlt,
  buttonText,
  buttonHref = "#",
  class: className,
} = Astro.props;
---

<div
  class={cx(
    "flex flex-col lg:flex-row items-center lg:items-stretch justify-between gap-4 lg:gap-12 bg-surface-default rounded-2xl overflow-hidden",
    className,
  )}
>
  <div
    class="flex flex-col justify-center items-start gap-6 w-full px-4 xl:px-16 lg:w-1/2 py-8"
  >
    <div class="flex flex-col gap-6 w-full">
      {
        items.map((item) => {
          return (
            <div class="flex flex-col gap-1">
              <div class="flex items-center gap-4">
                <Icon name={item.icon as string} />
                <Heading as="h3" variant="primary">
                  {item.title}
                </Heading>
              </div>
              <p class="text-body-sm text-text-secondary leading-relaxed">
                {item.description}
              </p>
            </div>
          );
        })
      }
    </div>

    <Button href={buttonHref} variant="primary" icon="arrow-right" class="mt-4">
      {buttonText}
    </Button>
  </div>

  <div class="lg:w-1/2 w-full h-full relative">
    <Image
      src={imageSrc as any}
      alt={imageAlt}
      class="w-full h-full object-cover"
      width={800}
      height={600}
      format="webp"
      quality="mid"
    />
  </div>
</div>
