---
import { cx } from "../../lib/utils";
import Button from "./Button.astro";
import { ArrowRight } from "lucide-astro";
import Heading from "./Heading.astro";

export interface Item {
  icon: string;
  title: string;
  description: string;
}

export interface Props {
  items?: Item[];
  imageSrc: string;
  imageAlt: string;
  buttonText: string;
  buttonHref?: string;
  class?: string;
}

const {
  items = [],
  imageSrc,
  imageAlt,
  buttonText,
  buttonHref = "#",
  class: className,
} = Astro.props;
---

<div
  class={cx(
    "flex flex-col lg:flex-row items-center lg:items-stretch justify-between gap-4 lg:gap-20 bg-surface-default rounded-2xl overflow-hidden",
    className,
  )}
>
  <div
    class="flex flex-col justify-center items-start gap-6 w-full px-4 lg:px-16 lg:w-1/2 py-8"
  >
    <div class="flex flex-col gap-6 w-full">
      {
        items.map((item) => (
          <div class="flex items-center gap-6 group">
            <img src={item.icon} alt={item.title} class="w-[52px] h-[52px]" />

            <div class="flex flex-col gap-1">
              <Heading as="h3" variant="primary">
                {item.title}
              </Heading>
              <p class="text-body-sm text-text-secondary leading-relaxed">
                {item.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>

    <Button href={buttonHref} variant="primary" icon={ArrowRight} class="mt-4">
      {buttonText}
    </Button>
  </div>

  <div class="lg:w-1/2 w-full h-full relative">
    <img src={imageSrc} alt={imageAlt} class="w-full h-full object-cover" />
  </div>
</div>
