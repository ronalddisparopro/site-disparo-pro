---
import { cx } from "../../lib/utils";
import Button from "./Button.astro";
import Heading from "./Heading.astro";
import { Image } from "astro:assets";
import Icon from "../Icon.astro";

export interface Item {
  icon: string | any;
  title: string;
  description: string;
}

export interface Props {
  items?: Item[];
  imageSrc: string | any;
  imageAlt: string;
  buttonText: string;
  buttonHref?: string;
  class?: string;
}

const {
  items = [],
  imageSrc,
  imageAlt,
  buttonText,
  buttonHref = "#",
  class: className,
} = Astro.props;
---

<div
  class={cx(
    "flex flex-col items-start lg:items-stretch justify-between gap-12 lg:gap-20 bg-surface-default px-4 lg:px-16 py-8 lg:py-12 rounded-2xl overflow-hidden lg:flex-row",
    className,
  )}
>
  <div
    class="flex flex-col justify-center items-start gap-8 w-full px-8 lg:px-0 lg:w-2/5"
  >
    <div class="flex flex-col gap-6 w-full">
      {
        items.map((item) => {
          return (
            <div class="flex flex-col gap-1">
              <div class="flex items-center gap-4">
                <Icon name={item.icon as string} size={24} />
                <Heading as="h3" variant="primary">
                  {item.title}
                </Heading>
              </div>
              <p class="text-body-sm text-text-secondary leading-tight">
                {item.description}
              </p>
            </div>
          );
        })
      }
    </div>

    <Button href={buttonHref} variant="primary" icon="arrow-right">
      {buttonText}
    </Button>
  </div>

  <div class="lg:w-1/2 w-full flex items-center justify-center">
    <div class="relative w-full overflow-hidden flex items-center justify-center">
      <Image
        src={imageSrc as any}
        alt={imageAlt}
        class="w-full h-full object-contain aspect-4/3 lg:aspect-auto"
        width={1000}
        height={800}
        format="webp"
        quality="high"
      />
    </div>
  </div>
</div>
