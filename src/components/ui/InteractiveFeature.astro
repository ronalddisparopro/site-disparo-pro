---
import { cx } from "../../lib/utils";
import Button from "./Button.astro";
import Heading from "./Heading.astro";
import { ArrowRight } from "lucide-astro";

export interface FeatureItem {
  icon: string;
  title: string;
  description: string;
  image: string;
}

export interface Props {
  items: FeatureItem[];
  buttonText?: string;
  buttonHref?: string;
  class?: string;
}

const {
  items = [],
  buttonText = "Crie sua conta agora!",
  buttonHref = "#",
  class: className,
} = Astro.props;
---

<div
  class={cx(
    "flex flex-col lg:flex-row items-center gap-8 lg:gap-12 rounded-2xl bg-surface-muted",
    className,
  )}
>
  <!-- Image Column -->
  <div
    class="w-full lg:w-1/2
         relative flex items-end justify-center
         min-h-[400px] lg:min-h-[657px]
         bg-[linear-gradient(220deg,var(--color-surface-default)_0%,var(--color-brand-primary)_100%)]
         rounded-bl-2xl rounded-tl-2xl pt-6 lg:pt-0"
  >
    <img
      id="active-feature-image"
      src={items[0]?.image}
      alt="Feature visualization"
      class="w-4/5 xl:w-full max-w-[440px] h-auto object-contain transition-all duration-500 ease-in-out"
    />
  </div>

  <!-- Content Column -->
  <div class="w-full lg:w-1/2 flex flex-col gap-6 px-4 lg:px-6">
    <div class="flex flex-col gap-6">
      {
        items.map((item, index) => (
          <button
            class={cx(
              "flex flex-col items-start gap-3 pb-4 text-left border-b border-brand-soft transition-all duration-300 group feature-item-btn",
              index === 0 ? "opacity-100" : "opacity-50 hover:opacity-80",
            )}
            data-image={item.image}
            data-index={index}
          >
            <div class="flex items-center justify-start gap-4">
              <img
                src={item.icon}
                alt={item.title}
                class="w-[52px] h-[52px] transition-transform group-active:scale-95"
              />
              <Heading as="h4" variant="primary">
                {item.title}
              </Heading>
            </div>

            <p class="text-body-sm text-text-secondary leading-relaxed">
              {item.description}
            </p>
          </button>
        ))
      }
    </div>

    <div>
      <Button variant="primary" icon={ArrowRight} href={buttonHref}>
        {buttonText}
      </Button>
    </div>
  </div>
</div>

<script>
  function setupInteractiveFeatures() {
    const buttons = document.querySelectorAll(".feature-item-btn");
    const imageElement = document.getElementById(
      "active-feature-image",
    ) as HTMLImageElement;

    if (!imageElement) return;

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const newImage = btn.getAttribute("data-image");

        // Update buttons state
        buttons.forEach((b) => {
          b.classList.remove("opacity-100");
          b.classList.add("opacity-50");
        });

        btn.classList.add("opacity-100");
        btn.classList.remove("opacity-50");

        // Animation
        if (newImage) {
          imageElement.style.opacity = "0";

          setTimeout(() => {
            imageElement.src = newImage;
            imageElement.style.opacity = "1";
          }, 300);
        }
      });
    });
  }

  setupInteractiveFeatures();
  document.addEventListener("astro:after-swap", setupInteractiveFeatures);
</script>
