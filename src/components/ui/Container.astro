---
import { cx } from "../../lib/utils";
export interface Props {
  class?: string;
  as?: string;
  fullWidth?: boolean;
}

const {
  class: className,
  as: Tag = "div",
  fullWidth = false,
  ...rest
} = Astro.props;
---

<Tag class={cx(!fullWidth && "container", className)} {...rest}>
  <slot />
</Tag>
