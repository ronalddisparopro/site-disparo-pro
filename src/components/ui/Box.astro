---
import { cx } from "../../lib/utils";
import Button from "./Button.astro";
import Icon from "../Icon.astro";

export interface Props {
  variant?: "primary" | "secondary" | "tertiary";
  class?: string;
  icon?: string | any;
  iconAlt?: string;
  title?: string;
  description?: string;
  buttonHref?: string;
  buttonText?: string;
}

const {
  variant = "primary",
  class: className,
  icon,
  iconAlt = "",
  title,
  description,
  buttonHref,
  buttonText,
  ...rest
} = Astro.props;

const baseClass =
  "w-full flex flex-col items-start gap-4 rounded-lg py-8 px-6 text-left transition-all hover:opacity-90";

const variants = {
  primary: "bg-surface-muted",
  secondary: "bg-surface-muted",
  tertiary:
    "bg-[linear-gradient(180deg,var(--color-brand-soft)_0%,rgba(255,255,255,0.19)_100%)]",
};

const titleStyles = {
  primary: "text-hero",
  secondary: "text-body-lg",
  tertiary: "text-body-lg",
};

const classes = cx(baseClass, variants[variant], className);

const isIconName = typeof icon === "string" && !icon.includes("/") && !icon.includes(".");
---

<div class={classes} {...rest}>
  {icon && <Icon name={icon} />}


  <div class="flex flex-col">
    {
      title && (
        <span class={cx("font-bold text-text-primary", titleStyles[variant])}>
          {title}
        </span>
      )
    }

    {
      description && (
        <p class="text-body-md text-text-secondary leading-relaxed">
          {description}
        </p>
      )
    }
    <slot />
  </div>

  {
    buttonHref && (
      <Button variant="secondary" href={buttonHref} class="w-full">
        {buttonText}
      </Button>
    )
  }
</div>
