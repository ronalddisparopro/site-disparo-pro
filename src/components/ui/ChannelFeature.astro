---
import { cx } from "../../lib/utils";
import Button from "./Button.astro";
import Heading from "./Heading.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export interface Props {
  id?: string;
  badge: string;
  title: string;
  features: string[];
  buttonText: string;
  buttonHref?: string;
  imageSrc: string | ImageMetadata;
  imageAlt: string;
  reverse?: boolean;
  class?: string;
}

const {
  id,
  badge,
  title,
  features,
  buttonText,
  buttonHref = "#",
  imageSrc,
  imageAlt,
  reverse = false,
  class: className,
} = Astro.props;
---

<div
  id={id}
  class={cx(
    "flex flex-col lg:flex-row items-center lg:items-stretch justify-between gap-12 lg:gap-20 bg-surface-default pb-0 pt-8 lg:pt-0 rounded-2xl overflow-hidden",
    !reverse ? "lg:pl-16" : "lg:flex-row-reverse lg:pr-16",
    className,
  )}
>
  <div
    class="flex flex-col justify-center items-start gap-6 w-full px-8 lg:px-0 lg:w-1/2"
  >
    <div class="bg-brand-soft px-4 py-2 rounded-lg">
      <span class="text-brand-primary font-semibold text-body-sm">
        {badge}
      </span>
    </div>

    <div class="flex flex-col gap-4">
      <Heading as="h2" variant="primary">
        {title}
      </Heading>

      <ul class="flex flex-col gap-3">
        {
          features.map((feature) => (
            <li class="flex items-start gap-3 text-text-secondary text-body-md lg:text-body-lg">
              <span class="mt-2.5 flex-shrink-0 w-1.5 h-1.5 rounded-full bg-current opacity-60" />
              <span class="leading-tight">{feature}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <Button href={buttonHref} variant="primary" icon="arrow-right">
      {buttonText}
    </Button>
  </div>

  <div class="lg:w-1/2 w-full h-full">
    <div class="relative h-full overflow-hidden">
      <Image
        src={imageSrc as any}
        alt={imageAlt}
        class="w-full h-full object-cover aspect-4/3 lg:aspect-auto"
        width={800}
        height={600}
        format="webp"
        quality="mid"
      />
    </div>
  </div>
</div>
