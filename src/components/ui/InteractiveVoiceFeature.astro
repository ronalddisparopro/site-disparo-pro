---
import { cx } from "../../lib/utils";
import Button from "./Button.astro";
import Heading from "./Heading.astro";
import { Image } from "astro:assets";
import Icon from "../Icon.astro";

export interface FeatureItem {
  icon: string | any;
  title: string;
  description: string;
  image: string | any;
  audio: string;
}

export interface Props {
  items: FeatureItem[];
  buttonText?: string;
  buttonHref?: string;
  class?: string;
}

const {
  items = [],
  buttonText = "Crie sua conta agora!",
  buttonHref = "#",
  class: className,
} = Astro.props;
---

<div
  class={cx(
    "flex flex-col lg:flex-row items-center gap-8 lg:gap-12 rounded-2xl bg-surface-muted",
    className,
  )}
  data-interactive-voice-feature
>
  <!-- Image Column -->
  <div
    class="w-full lg:w-1/2
         relative flex items-end justify-center
         h-[480px] md:h-[550px] lg:h-[657px]
         bg-[linear-gradient(220deg,var(--color-surface-default)_0%,var(--color-brand-primary)_100%)]
         rounded-bl-2xl rounded-tl-2xl pt-6 overflow-hidden"
  >
    <div
      class="relative w-full max-w-[440px] flex flex-col items-center h-full"
    >
      {
        items.map((item, index) => (
          <Image
            src={item.image as any}
            alt={item.title}
            width={500}
            height={900}
            class={cx(
              "absolute bottom-0 left-1/2 -translate-x-1/2 w-auto h-[92%] max-w-[95%] object-contain transition-all duration-500 ease-in-out voice-main-img",
              index === 0
                ? "opacity-100 z-10 translate-y-0"
                : "opacity-0 z-0 translate-y-8",
            )}
            data-image-index={index}
            format="webp"
            quality="high"
          />
        ))
      }

      <!-- Audio Player Overlay -->
      <div
        class="absolute bottom-28 md:bottom-36 lg:bottom-44 left-1/2 -translate-x-1/2 w-4/6 md:w-3/5 lg:w-4/6 bg-surface-default rounded-full p-2 md:p-3 flex items-center gap-3 z-30"
      >
        <audio
          data-active-audio
          src={items[0]?.audio}
          class="w-full h-8 md:h-10"
          controls></audio>
      </div>
    </div>
  </div>

  <!-- Content Column -->
  <div class="w-full lg:w-1/2 flex flex-col gap-6 px-4 lg:px-6 py-8">
    <div class="flex flex-col gap-6">
      {
        items.map((item, index) => {
          return (
            <button
              class={cx(
                "flex flex-col items-start gap-3 pb-4 text-left border-b border-brand-soft transition-all duration-300 group feature-item-btn",
                index === 0 ? "opacity-100" : "opacity-50 hover:opacity-80",
              )}
              data-index={index}
              data-audio={item.audio}
            >
              <div class="flex items-center justify-start gap-4">
                <Icon name={item.icon as string} />
                <Heading as="h4" variant="primary">
                  {item.title}
                </Heading>
              </div>

              <p class="text-body-sm text-text-secondary leading-relaxed">
                {item.description}
              </p>
            </button>
          );
        })
      }
    </div>

    <div>
      <Button variant="primary" icon="arrow-right" href={buttonHref}>
        {buttonText}
      </Button>
    </div>
  </div>
</div>

<script>
  function setupInteractiveVoiceFeatures() {
    const containers = document.querySelectorAll(
      "[data-interactive-voice-feature]",
    );

    containers.forEach((container) => {
      const buttons = container.querySelectorAll(".feature-item-btn");
      const images = container.querySelectorAll(".voice-main-img");
      const audioElement = container.querySelector(
        "[data-active-audio]",
      ) as HTMLAudioElement;

      if (!audioElement) return;

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const index = btn.getAttribute("data-index");
          const newAudio = btn.getAttribute("data-audio");

          // Update buttons state
          buttons.forEach((b) => {
            b.classList.remove("opacity-100");
            b.classList.add("opacity-50");
          });

          btn.classList.add("opacity-100");
          btn.classList.remove("opacity-50");

          // Visibility
          images.forEach((img) => {
            if (img.getAttribute("data-image-index") === index) {
              img.classList.add("opacity-100", "z-10", "translate-y-0");
              img.classList.remove("opacity-0", "z-0", "translate-y-8");
            } else {
              img.classList.remove("opacity-100", "z-10", "translate-y-0");
              img.classList.add("opacity-0", "z-0", "translate-y-8");
            }
          });

          // Update and Reload Audio
          if (newAudio) {
            audioElement.src = newAudio;
            audioElement.load();
          }
        });
      });
    });
  }

  setupInteractiveVoiceFeatures();
  document.addEventListener("astro:page-load", setupInteractiveVoiceFeatures);
</script>
