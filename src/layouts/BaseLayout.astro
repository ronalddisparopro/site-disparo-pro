---
import "../styles/globals.css";
import SEO from "../components/SEO.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { SeoProps } from "../types/seo";

export interface Props {
  seo?: SeoProps;
}

const { seo } = Astro.props;
---

<html lang="pt-BR" class="scroll-smooth">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap"
      rel="stylesheet"
    />
    {
      seo ? (
        <SEO {...seo} />
      ) : (
        <SEO
          title="Dispare SMS e Torpedo de Voz em Massa | Disparo Pro"
          description="Alcance até 98% do seu público-alvo! Tenha acesso a uma plataforma simples e intuitiva para disparar mensagens em massa."
        />
      )
    }

    <script is:inline>
      (function () {
        const STORAGE_KEY = "utmParameters";
        const urlParams = new URLSearchParams(window.location.search);
        const utms = [
          "utm_source",
          "utm_medium",
          "utm_campaign",
          "utm_term",
          "utm_content",
        ];

        let currentUtms = {};
        let hasNewUtm = false;

        utms.forEach((utm) => {
          const val = urlParams.get(utm);
          if (val) {
            currentUtms[utm] = val;
            hasNewUtm = true;
          }
        });

        if (hasNewUtm) {
          let stored = localStorage.getItem(STORAGE_KEY);
          let data = {};
          try {
            data = stored ? JSON.parse(stored) : {};
          } catch (e) {
            data = {};
          }

          // Define as UTMs do primeiro toque se ainda não existirem
          if (!data.first_touch) {
            data.first_touch = { ...currentUtms };
          }

          // Atualiza as UTMs do último toque (opcional, mas útil)
          data.last_touch = { ...currentUtms };

          localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-sans overflow-x-hidden">
    <Header />
    <main class="grow w-full overflow-x-hidden">
      <slot />
    </main>
    <Footer />
  </body>
</html>
