---
import BaseLayout from "./BaseLayout.astro";
import type { SeoProps } from "../types/seo";
import type { BlogPost } from "../types/blog";
import Container from "../components/ui/Container.astro";
import Heading from "../components/ui/Heading.astro";
import AuthorBox from "../components/AuthorBox.astro";
import { ROUTES } from "../lib/routes";

export interface Props {
  post: BlogPost;
  seo: SeoProps;
}

const { post, seo } = Astro.props;
---

<BaseLayout seo={seo}>
  <article class="py-12 md:py-20 lg:py-24">
    <Container class="max-w-4xl mx-auto">
      <!-- Breadcrumbs -->
      <nav class="mb-8 text-sm text-text-tertiary" aria-label="Breadcrumb">
        <ol class="list-none p-0 inline-flex">
          <li class="flex items-center">
            <a href="/" class="hover:text-text-primary">Home</a>
            <span class="mx-2">/</span>
          </li>
          <li class="flex items-center">
            <a href="/blog" class="hover:text-text-primary">Blog</a>
            <span class="mx-2">/</span>
          </li>
          <li class="flex items-center">
            <a
              href={ROUTES.BLOG.CATEGORY(post.category)}
              class="hover:text-text-primary capitalize">{post.category}</a
            >
            <span class="mx-2">/</span>
          </li>
          <li class="text-text-primary font-medium" aria-current="page">
            {post.title}
          </li>
        </ol>
      </nav>

      <div class="mb-8">
        <Heading as="h1" class="mb-6">{post.title}</Heading>
        <p class="text-xl text-text-secondary mb-8">{post.excerpt}</p>

        <!-- Placeholder da Imagem (simulando um img sem src real ou class utility) -->
        <div
          class="w-full h-[400px] bg-surface-muted rounded-xl mb-8 flex items-center justify-center text-text-tertiary"
        >
          Capa: {post.coverImage}
        </div>
      </div>

      <AuthorBox author={post.author} publishedAt={post.publishedAt} />

      <div
        class="prose prose-lg max-w-none prose-h2:text-3xl prose-h2:font-semibold prose-h2:mt-12 prose-h2:mb-6 prose-p:text-text-secondary prose-p:leading-relaxed"
      >
        <slot />
      </div>
    </Container>
  </article>
</BaseLayout>
